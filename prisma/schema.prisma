generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// מחקנו את model User - קלארק מנהל את המשתמשים
// אנחנו רק שומרים את ה-ID שלהם בטבלת המניות

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String
  name      String?  // הפכתי לאופציונלי למקרה שאין שם
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())
  
  userId    String   // <--- שינוי קריטי: ID של Clerk הוא מחרוזת (למשל user_2xyz...)
  
  @@index([userId]) // אינדקס לשליפות מהירות לפי משתמש
}